<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ownerseye.ownerseye.domain.store.persistence.mapper.StoreMapper">

    <select id="findByUserId" resultType="com.ownerseye.ownerseye.domain.store.persistence.entity.StoreEntity">
        SELECT store_id, user_id, store_name, created_at
        FROM store
        WHERE user_id = #{userId}
    </select>

</mapper>
